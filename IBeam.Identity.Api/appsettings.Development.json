{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "IBeam": {
    "Identity": {
      "AzureTable": {
        "StorageConnectionString": "UseDevelopmentStorage=true",
        "TablePrefix": "IBeam",
        "IndexTableName": "AspNetIndex",
        "UserTableName": "AspNetUsers",
        "RoleTableName": "AspNetRoles"
      },
      "Jwt": {
        "Issuer": "IBeam.Identity",
        "Audience": "IBeam.Identity.Api",
        "SigningKey": "IBeam_Development_Signing_Key_32chars_minimum_2026",
        "AccessTokenMinutes": 60,
        "PreTenantTokenMinutes": 10,
        "RefreshTokenDays": 30,
        "ClockSkewSeconds": 60
      },
      "Features": {
        "Otp": true,
        "PasswordAuth": true,
        "TwoFactor": true,
        "OAuth": false,
        "TenantSelection": true,
        "ClaimsEnrichment": true
      },
      "OAuth": {
        "StateTtlMinutes": 10,
        "Providers": {
          "google": {
            "Enabled": false,
            "ClientId": "",
            "ClientSecret": "",
            "AuthorizationEndpoint": "https://accounts.google.com/o/oauth2/v2/auth",
            "TokenEndpoint": "https://oauth2.googleapis.com/token",
            "UserInfoEndpoint": "https://openidconnect.googleapis.com/v1/userinfo",
            "Scope": "openid profile email"
          },
          "microsoft": {
            "Enabled": false,
            "ClientId": "",
            "ClientSecret": "",
            "AuthorizationEndpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
            "TokenEndpoint": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
            "UserInfoEndpoint": "https://graph.microsoft.com/oidc/userinfo",
            "Scope": "openid profile email"
          }
        }
      }
    }
  }
}
