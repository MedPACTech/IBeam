{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "IBeam": {
    "Identity": {
      "AzureTable": {
        "StorageConnectionString": "UseDevelopmentStorage=true",
        "TablePrefix": "IBeam",
        "IndexTableName": "AspNetIndex",
        "UserTableName": "AspNetUsers",
        "RoleTableName": "AspNetRoles"
      },
      "Jwt": {
        "Issuer": "IBeam.Identity",
        "Audience": "IBeam.Identity.Api",
        "SigningKey": "IBeam_Development_Signing_Key_32chars_minimum_2026",
        "AccessTokenMinutes": 60,
        "PreTenantTokenMinutes": 10,
        "ClockSkewSeconds": 60
      }
    }
  }
}
