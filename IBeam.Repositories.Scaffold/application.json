{
  "IBeam": {
    "Communications": {
      "Email": {
        "AzureCommunications": {
          "ConnectionString": "endpoint=https://<your-resource>.communication.azure.com/;accesskey=<your-access-key>",
          "DefaultFromAddress": "DoNotReply@yourdomain.com",
          "DefaultFromDisplayName": "IBeam Notifications"
        }
      }
    },
    "Otp": {
      "CodeLength": 6,
      "ExpirationMinutes": 10,
      "MaxAttempts": 5
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
