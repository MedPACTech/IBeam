{
  "IBeam": {
    "Environment": "Local",
    "Identity": {
      "Issuer": "IBeam",
      "Audience": "IBeam.Clients",
      "TokenExpirationMinutes": 60
    },
    "Otp": {
      "CodeLength": 6,
      "ExpirationMinutes": 10,
      "MaxAttempts": 5
    },
    "Communications": {
      "Email": {
        "Provider": "AzureCommunications",
        "AzureCommunications": {
          "ConnectionString": "endpoint=https://...;accesskey=...",
          "DefaultFromAddress": "DoNotReply@yourdomain.com",
          "DefaultFromDisplayName": "IBeam Notifications"
        }
      },
      "Sms": {
        "Provider": "AzureCommunications",
        "AzureCommunications": {
          "ConnectionString": "endpoint=https://...;accesskey=...",
          "DefaultFromNumber": "+10000000000"
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
