<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageId>IBeam.Services</PackageId>
    <Version>2.0.3</Version>
    <Authors>MedPAC Technologies</Authors>
    <Company>MedPAC Technologies</Company>
    <PackageDescription>
      Root services package that aggregates abstractions and core service implementations.
    </PackageDescription>
    <RepositoryUrl>https://github.com/MedPACTech/IBeam</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\IBeam.Services.Abstractions\IBeam.Services.Abstractions.csproj" />
    <ProjectReference Include="..\IBeam.Services.Core\IBeam.Services.Core.csproj" />
  </ItemGroup>

</Project>
