
{
  "IBeam": {
    "Communications": {
      "Email": {
        "AzureCommunications": {
          "ConnectionString": "endpoint=https://...;accesskey=...",
          "DefaultFromAddress": "DoNotReply@yourdomain.com",
          "DefaultFromDisplayName": "IBeam Notifications"
        }
      }
    },
    "Authentication": {
      "Otp": {
        "Enabled": true,
        "CodeLength": 6,
        "ExpirationMinutes": 10,
        "MaxAttempts": 5
      }
    },
    "Platform": {
      "ApplicationName": "IBeam API",
      "Environment": "Development"
    }
  }
}
