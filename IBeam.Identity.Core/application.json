        "CodeLength": 6,
        "ExpirationMinutes": 10,
        "MaxAttempts": 5,
        "ReuseBlockedMinutes": 15,
        "HashAlgorithm": "SHA256"
      }
    },
    "Communications": {
      "Email": {
        "AzureCommunications": {
          "ConnectionString": "endpoint=https://...;accesskey=...",
