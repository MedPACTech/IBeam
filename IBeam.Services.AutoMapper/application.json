{
  "IBeam": {
    "Communications": {
      "Email": {
        "AzureCommunications": {
          "ConnectionString": "endpoint=https://...;accesskey=...",
          "DefaultFromAddress": "DoNotReply@yourdomain.com",
          "DefaultFromDisplayName": "IBeam Notifications"
        }
      }
    },
    "Otp": {
      "CodeLength": 6,
      "ExpirationMinutes": 10,
      "MaxAttempts": 5,
      "ThrottleSeconds": 60
    },
    "Security": {
      "RequireHttps": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
